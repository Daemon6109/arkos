{
  "name": "arkos",
  "version": "0.1.0",
  "description": "Cognitive AI orchestration engine — local, modular, vision-first",
  "type": "module",
  "bin": {
    "arkos": "./src/main.ts"
  },
  "scripts": {
    "dev": "bun src/main.ts",
    "start": "bun src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "check": "bunx tsc --noEmit",
    "serve": "bun src/main.ts serve",
    "lint": "bunx biome check --apply src/"
  },
  "dependencies": {
    "ollama": "^0.5.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  }
}
